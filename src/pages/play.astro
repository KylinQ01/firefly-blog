---
import { Icon } from "astro-icon/components";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
---

<MainGridLayout title="小游戏" description="来玩一局 2048">
  <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-6 md:px-9 py-6 relative w-full">
      <div class="mb-4 flex items-center justify-between flex-wrap gap-3">
        <div class="flex items-center gap-3">
          <div class="h-8 w-8 rounded-lg bg-(--primary) flex items-center justify-center text-white dark:text-black/70">
            <Icon is:inline name="material-symbols:sports-esports" class="text-[1.5rem]"></Icon>
          </div>
          <div class="text-2xl font-bold text-neutral-900 dark:text-neutral-100">2048</div>
        </div>
        <div class="flex items-center gap-4">
          <div class="rounded-xl bg-(--primary)/10 px-4 py-2 text-center">
            <div class="text-[11px] text-neutral-500">分数</div>
            <div id="score" class="text-xl font-black text-(--primary)">0</div>
          </div>
          <button id="restart-btn" class="btn-regular rounded-lg px-4 py-2 text-sm font-medium">重新开始</button>
        </div>
      </div>
      <div id="game-board" class="grid grid-cols-4 gap-2 rounded-2xl bg-neutral-200/60 p-3 dark:bg-neutral-800/60 mx-auto max-w-sm"></div>
      <p class="mt-3 text-center text-xs text-neutral-400 dark:text-neutral-500">方向键移动 | 合并相同数字达到 2048</p>
    </div>
  </div>
</MainGridLayout>

<style>
  .tile { aspect-ratio: 1; display: flex; align-items: center; justify-content: center; font-weight: 800; border-radius: 0.5rem; transition: all 0.12s ease; font-size: 1.25rem; }
  .tile-0 { background: rgba(0,0,0,0.04); }
  .tile-2 { background: #eee4da; color: #776e65; }
  .tile-4 { background: #ede0c8; color: #776e65; }
  .tile-8 { background: #f2b179; color: #f9f6f2; }
  .tile-16 { background: #f59563; color: #f9f6f2; }
  .tile-32 { background: #f67c5f; color: #f9f6f2; }
  .tile-64 { background: #f65e3b; color: #f9f6f2; }
  .tile-128 { background: #edcf72; color: #f9f6f2; font-size: 1.1rem; }
  .tile-256 { background: #edcc61; color: #f9f6f2; font-size: 1.1rem; }
  .tile-512 { background: #edc850; color: #f9f6f2; font-size: 1.1rem; }
  .tile-1024 { background: #edc53f; color: #f9f6f2; font-size: 0.9rem; }
  .tile-2048 { background: #edc22e; color: #f9f6f2; font-size: 0.9rem; }
  .tile-super { background: #3c3a32; color: #f9f6f2; font-size: 0.8rem; }
</style>

<script is:inline>
(function() {
  let board = Array(4).fill(null).map(() => Array(4).fill(0));
  let score = 0;
  let gameOver = false;

  function addTile() {
    const empty = [];
    for (let r = 0; r < 4; r++)
      for (let c = 0; c < 4; c++)
        if (board[r][c] === 0) empty.push([r, c]);
    if (!empty.length) return;
    const [r, c] = empty[Math.floor(Math.random() * empty.length)];
    board[r][c] = Math.random() < 0.9 ? 2 : 4;
  }

  function slide(row) {
    let arr = row.filter(v => v);
    for (let i = 0; i < arr.length - 1; i++) {
      if (arr[i] === arr[i + 1]) { arr[i] *= 2; score += arr[i]; arr[i + 1] = 0; }
    }
    arr = arr.filter(v => v);
    while (arr.length < 4) arr.push(0);
    return arr;
  }

  function move(dir) {
    if (gameOver) return;
    const old = board.map(r => [...r]);
    if (dir === 0) { for (let c = 0; c < 4; c++) { const col = slide([board[0][c], board[1][c], board[2][c], board[3][c]]); for (let r = 0; r < 4; r++) board[r][c] = col[r]; } }
    else if (dir === 1) { for (let c = 0; c < 4; c++) { const col = slide([board[3][c], board[2][c], board[1][c], board[0][c]]).reverse(); for (let r = 0; r < 4; r++) board[r][c] = col[r]; } }
    else if (dir === 2) { for (let r = 0; r < 4; r++) board[r] = slide(board[r]); }
    else if (dir === 3) { for (let r = 0; r < 4; r++) board[r] = slide([...board[r]].reverse()).reverse(); }
    if (JSON.stringify(old) !== JSON.stringify(board)) { addTile(); render(); checkGameOver(); }
  }

  function checkGameOver() {
    for (let r = 0; r < 4; r++)
      for (let c = 0; c < 4; c++) {
        if (board[r][c] === 0) return;
        if (c < 3 && board[r][c] === board[r][c + 1]) return;
        if (r < 3 && board[r][c] === board[r + 1][c]) return;
      }
    gameOver = true;
    setTimeout(() => alert('游戏结束！最终分数：' + score), 200);
  }

  function render() {
    const el = document.getElementById("game-board");
    const sc = document.getElementById("score");
    if (!el || !sc) return;
    sc.textContent = score;
    el.innerHTML = board.flat().map(v => {
      const cls = v >= 2048 ? 'tile-super' : 'tile-' + v;
      return '<div class="tile ' + cls + '">' + (v || '') + '</div>';
    }).join('');
  }

  function start() {
    board = Array(4).fill(null).map(() => Array(4).fill(0));
    score = 0;
    gameOver = false;
    addTile(); addTile();
    render();
  }

  document.addEventListener("keydown", e => {
    const map = { ArrowUp: 0, ArrowDown: 1, ArrowLeft: 2, ArrowRight: 3, w: 0, s: 1, a: 2, d: 3 };
    if (e.key in map) { e.preventDefault(); move(map[e.key]); }
  });
  document.getElementById("restart-btn")?.addEventListener("click", start);
  start();
})();
</script>