---
import { Icon } from "astro-icon/components";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { url } from "@/utils/url-utils";
---

<MainGridLayout title="404" description="页面未找到">
    <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-96">
        <div class="card-base z-10 px-9 py-12 relative w-full flex flex-col items-center justify-center text-center">
            <div class="text-8xl md:text-9xl font-black text-(--primary)/15 mb-2 select-none">
                404
            </div>

            <div class="mb-6">
                <Icon is:inline name="material-symbols:signal-disconnected" class="text-5xl text-(--primary)/70" />
            </div>

            <div class="text-2xl md:text-3xl font-bold mb-3 text-neutral-800 dark:text-neutral-100">
                哎呀，页面走丢了
            </div>

            <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-8 max-w-sm leading-relaxed">
                你访问的页面可能被风吹走了、被我删掉了，或者从来没有存在过。
                <br />
                但不用担心，从这里可以找到回家的路。
            </p>

            <div class="flex items-center gap-3 flex-wrap justify-center">
                <a
                    href={url("/")}
                    class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-(--primary) text-white text-sm font-medium transition-all duration-200 hover:brightness-110 active:scale-95"
                >
                    <Icon is:inline name="material-symbols:home" class="text-lg" />
                    回首页
                </a>
                <a
                    href={url("/moments/")}
                    class="btn-regular inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-medium transition-all duration-200"
                >
                    <Icon is:inline name="material-symbols:tips-and-updates" class="text-lg" />
                    看看动态
                </a>
                <a
                    href={url("/guestbook/")}
                    class="btn-regular inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-medium transition-all duration-200"
                >
                    <Icon is:inline name="material-symbols:chat" class="text-lg" />
                    留言告诉我
                </a>
            </div>

            <div class="absolute top-6 left-6 opacity-8">
                <Icon is:inline name="material-symbols:sentiment-sad" class="text-4xl text-(--primary)" />
            </div>
            <div class="absolute bottom-6 right-6 opacity-8">
                <Icon is:inline name="material-symbols:search-off" class="text-4xl text-(--primary)" />
            </div>
        </div>
    </div>
</MainGridLayout>

<style>
    .card-base {
        animation: fadeInUp 0.6s ease-out;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>