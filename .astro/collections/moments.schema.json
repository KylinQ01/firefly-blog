{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "default": "",
      "type": "string"
    },
    "published": {
      "type": "string",
      "format": "date-time"
    },
    "updated": {
      "type": "string",
      "format": "date-time"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "images": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "mood": {
      "default": "thinking",
      "type": "string",
      "enum": [
        "happy",
        "coding",
        "gaming",
        "late-night",
        "thinking"
      ]
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "published"
  ]
}